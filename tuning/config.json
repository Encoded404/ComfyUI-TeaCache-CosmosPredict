{
    "comfy_dir": "/path/to/ComfyUI",
    "model_name": "anima-base-v1.0.safetensors",
    "clip_name": "qwen_3_06b_base.safetensors",
    "clip_type": "qwen_image",
    "vae_name": "qwen_image_vae.safetensors",

    "sampling": {
        "default_steps": 30,
        "step_variants": [25, 28, 30, 35, 40],
        "step_weights": [0.05, 0.10, 0.70, 0.10, 0.05],
        "cfg": 5.0,
        "sampler": "euler_ancestral",
        "scheduler": "simple",
        "width": 512,
        "height": 512
    },

    "calibration": {
        "prompts_file": "prompts/calibration.json",
        "prompt_selection": "from_top",
        "prompt_tag_filter": ["-nsfw"],
        "num_prompts": 30,
        "seeds": [34635345, 53453634, 267454, 123],
        "negative_prompt": ""
    },

    "optimization": {
        "sources": ["t_emb", "first_block_shift"],
        "metric_types": ["mean_only", "mean_and_max", "mean_max_std"],
        "metric_weights_scenarios": [
            {"mean": 1.0},
            {"mean": 0.7, "max": 0.3},
            {"mean": 0.5, "max": 0.3, "std": 0.2}
        ],
        "mapping_types": ["identity", "polynomial"],
        "accumulation_types": ["hard_reset", "carry_over"],
        "accumulation_params": [
            {},
            {"leak_factor": 0.9},
            {"leak_factor": 0.8}
        ],
        "residual_strategies": ["hard"],
        "step_schedules": ["constant", "cosine"],
        "signal_scales": {
            "t_emb": [10, 25, 50, 100, 200, 500],
            "first_block_shift": [1.0],
            "pooled_latent": [1.0, 10, 50]
        },
        "threshold_range": [0.01, 10.0],
        "threshold_count": 300,
        "poly_degree": 4,
        "cross_validate": true,
        "cv_holdout_fraction": 0.2
    },

    "validation": {
        "prompts_file": "prompts/benchmark.json",
        "prompt_selection": "from_top",
        "prompt_tag_filter": ["-nsfw"],
        "num_prompts": 8,
        "seeds": [34635345, 53453634, 267454, 123],
        "top_k": 20,
        "extra_threshold_sweep": [0.02, 0.04, 0.06, 0.07, 0.08, 0.10, 0.15, 0.20, 0.30, 0.50, 0.70, 1.0, 2.0, 5.0]
    },

    "output_dir": "outputs"
}
