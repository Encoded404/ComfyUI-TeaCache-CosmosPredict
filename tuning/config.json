{
    "comfy_dir": "/path/to/ComfyUI",
    "model_name": "anima-base-v1.0.safetensors",
    "clip_name": "qwen_3_06b_base.safetensors",
    "clip_type": "qwen_image",
    "vae_name": "qwen_image_vae.safetensors",

    "sampling": {
        "default_steps": 30,
        "step_variants": [25, 28, 30, 35, 40],
        "step_weights": [0.05, 0.10, 0.70, 0.10, 0.05],
        "cfg": 5.0,
        "sampler": "er_sde",
        "scheduler": "normal",
        "width": 512,
        "height": 512,
        "sampler_variants": ["er_sde", "dpmpp_2m_sde", "euler_a"],
        "scheduler_variants": ["normal", "simple"],
        "cfg_variants": [4.0, 4.5, 5.0, 5.5]
    },

    "calibration": {
        "prompts_file": "prompts/calibration.json",
        "prompt_selection": "semantic_diversity",
        "prompt_tag_filter": [],
        "num_prompts": 30,
        "seeds": [34635345, 53453634, 267454, 123],
        "negative_prompt": "",
        "track_per_block": true
    },

    "optimization": {
        "sources": ["t_emb", "first_block_shift", "pooled_latent"],
        "metric_types": ["mean_only", "mean_and_max", "mean_max_std"],
        "metric_weights_scenarios": [
            {"mean": 1.0},
            {"mean": 0.7, "max": 0.3},
            {"mean": 0.5, "max": 0.3, "std": 0.2}
        ],
        "mapping_types": ["identity", "polynomial", "power_law", "softplus"],
        "mapping_params_scenarios": {
            "power_law": [
                {"k": 0.5, "alpha": 0.3},
                {"k": 1.0, "alpha": 0.5},
                {"k": 0.3, "alpha": 0.7}
            ],
            "softplus": [
                {"k": 10.0, "offset": 0.03},
                {"k": 10.0, "offset": 0.05},
                {"k": 5.0,  "offset": 0.10}
            ]
        },
        "accumulation_types": ["hard_reset", "carry_over", "leaky", "windowed"],
        "accumulation_params": [
            {},
            {"leak_factor": 0.95},
            {"leak_factor": 0.90},
            {"leak_factor": 0.80},
            {"window_size": 3},
            {"window_size": 5},
            {"window_size": 7}
        ],
        "residual_strategies": ["hard", "blended", "scaled"],
        "residual_params_scenarios": [
            {},
            {"scale": 0.8},
            {"scale": 0.5}
        ],
        "step_schedules": ["constant", "cosine", "linear_ramp", "linear_decay", "bell"],
        "signal_scales": {
            "t_emb": [10, 50, 100, 200],
            "first_block_shift": [1.0],
            "pooled_latent": [1.0, 10, 50]
        },
        "auto_scale_target": 1.0,
        "block_modes": ["all_or_nothing", "split_fraction", "split_groups"],
        "block_params_scenarios": {
            "split_fraction": [
                {"always_fraction": 0.25},
                {"always_fraction": 0.36},
                {"always_fraction": 0.50}
            ],
            "split_groups": [
                {"always_groups": [0], "cache_groups": [1, 2]},
                {"always_groups": [0, 1], "cache_groups": [2]},
                {"always_groups": [0, 1, 2], "cache_groups": []}
            ]
        },
        "candidate_thresholds": [0.01, 0.07, 0.20],
        "pareto_threshold_range": [0.001, 10.0],
        "pareto_threshold_count": 500,
        "poly_degree": 4,
        "quality_scoring": {
            "type": "exponential",
            "target": 0.05
        },
        "cross_validate": true,
        "cv_holdout_fraction": 0.2,
        "max_candidates": 0
    },

    "validation": {
        "prompts_file": "prompts/benchmark.json",
        "prompt_selection": "semantic_diversity",
        "prompt_tag_filter": [],
        "num_prompts": 8,
        "seeds": [34635345, 53453634, 267454, 123],
        "top_k": 20,
        "extra_threshold_sweep": [0.02, 0.04, 0.06, 0.07, 0.08, 0.10, 0.15, 0.20, 0.30, 0.50, 0.70, 1.0, 2.0, 5.0]
    },

    "output_dir": "outputs"
}
